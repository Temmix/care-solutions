# Base URL of the Clinvara API, including the /api prefix.
# Local dev (device on same network): use your machine's LAN IP, not localhost,
# because the phone/emulator can't reach the host's loopback.
#   EXPO_PUBLIC_API_URL=http://192.168.1.20:3000/api
# Staging/prod: point at the ALB.
#   EXPO_PUBLIC_API_URL=https://api.clinvara.com/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Org timezone for interpreting shift HH:mm times (default Europe/London).
# EXPO_PUBLIC_APP_TIMEZONE=Europe/London
