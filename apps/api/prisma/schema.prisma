datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

// ─── Enums ────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  ADMIN
  CLINICIAN
  NURSE
  CARER
  PATIENT
  SYSTEM
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum PatientStatus {
  ACTIVE
  INACTIVE
  DECEASED
}

enum IdentifierType {
  NHS_NUMBER
  MRN
  PASSPORT
  OTHER
}

enum ContactRelationship {
  NEXT_OF_KIN
  EMERGENCY
  CARER
  GUARDIAN
  OTHER
}

enum PatientEventType {
  CREATED
  UPDATED
  ADMISSION
  DISCHARGE
  TRANSFER
  NOTE
  ASSESSMENT
  REFERRAL
  DEMOGRAPHIC_CHANGE
  CARE_PLAN_CREATED
  CARE_PLAN_UPDATED
  MEDICATION_PRESCRIBED
  MEDICATION_ADMINISTERED
}

enum OrganizationType {
  HOSPITAL
  GP_PRACTICE
  CARE_HOME
  COMMUNITY_SERVICE
  MENTAL_HEALTH_TRUST
  OTHER
}

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
}

enum CarePlanStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
  ENTERED_IN_ERROR
}

enum CarePlanCategory {
  NURSING
  PHYSIOTHERAPY
  MENTAL_HEALTH
  PALLIATIVE
  GENERAL
}

enum GoalStatus {
  PROPOSED
  ACCEPTED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ActivityType {
  MEDICATION
  EXERCISE
  APPOINTMENT
  OBSERVATION
  EDUCATION
  REFERRAL
  OTHER
}

enum ActivityStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssessmentStatus {
  DRAFT
  COMPLETED
  REVIEWED
  CANCELLED
  ENTERED_IN_ERROR
}

enum RiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  VERY_HIGH
}

enum MedicationRequestStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  STOPPED
  CANCELLED
  ENTERED_IN_ERROR
}

enum MedicationAdminStatus {
  IN_PROGRESS
  COMPLETED
  NOT_DONE
  ENTERED_IN_ERROR
}

enum MedicationRoute {
  ORAL
  TOPICAL
  INTRAVENOUS
  INTRAMUSCULAR
  SUBCUTANEOUS
  INHALED
  RECTAL
  SUBLINGUAL
  OTHER
}

enum MedicationForm {
  TABLET
  CAPSULE
  LIQUID
  INJECTION
  CREAM
  OINTMENT
  INHALER
  PATCH
  DROPS
  SUPPOSITORY
  OTHER
}

// ─── Multi-Tenancy ──────────────────────────────────────

enum MembershipStatus {
  ACTIVE
  INACTIVE
}

model UserTenantMembership {
  id             String           @id @default(uuid())
  userId         String
  organizationId String
  role           Role             @default(CARER)
  status         MembershipStatus @default(ACTIVE)
  joinedAt       DateTime         @default(now())
  leftAt         DateTime?

  user         User         @relation("UserMemberships", fields: [userId], references: [id])
  organization Organization @relation("TenantMemberships", fields: [organizationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@index([status])
  @@map("user_tenant_memberships")
}

// ─── Phase 3: Workforce Enums ──────────────────────────

enum ShiftType {
  EARLY
  LATE
  NIGHT
  LONG_DAY
  TWILIGHT
  CUSTOM
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AvailabilityType {
  AVAILABLE
  UNAVAILABLE
  ANNUAL_LEAVE
  SICK_LEAVE
  TRAINING
}

// ─── Phase 3: Shift Swap Enums ──────────────────────────

enum ShiftSwapStatus {
  PENDING
  ACCEPTED
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

// ─── Phase 3: Discharge Planning Enums ──────────────────

enum DischargePlanStatus {
  DRAFT
  IN_PROGRESS
  READY
  COMPLETED
  CANCELLED
}

enum DischargeTaskType {
  MEDICATION_REVIEW
  CARE_PACKAGE
  TRANSPORT
  FOLLOW_UP_APPOINTMENT
  EQUIPMENT
  PATIENT_EDUCATION
  FAMILY_NOTIFICATION
  GP_LETTER
}

enum DischargeTaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

// ─── Phase 3: Patient Flow Enums ───────────────────────

enum EncounterStatus {
  PLANNED
  ARRIVED
  IN_PROGRESS
  ON_LEAVE
  FINISHED
  CANCELLED
}

enum EncounterClass {
  INPATIENT
  OUTPATIENT
  EMERGENCY
  HOME_HEALTH
}

enum AdmissionSource {
  GP_REFERRAL
  EMERGENCY
  TRANSFER
  SELF_REFERRAL
  OTHER
}

enum DischargeDestination {
  HOME
  CARE_HOME
  HOSPITAL_TRANSFER
  DECEASED
  OTHER
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  CLOSED
}

enum LocationType {
  WARD
  ROOM
  BED
  DEPARTMENT
  WING
}

// ─── Auth & System ────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  role               Role     @default(PATIENT)
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String?
  tenant   Organization? @relation("TenantUsers", fields: [tenantId], references: [id])

  auditLogs      AuditLog[]
  patient        Patient?
  practitioner   Practitioner?
  recordedEvents PatientEvent[] @relation("PatientEventRecorder")

  authoredCarePlans CarePlan[]     @relation("CarePlanAuthor")
  carePlanNotes     CarePlanNote[] @relation("CarePlanNoteAuthor")

  performedAssessments Assessment[] @relation("AssessmentPerformer")
  reviewedAssessments  Assessment[] @relation("AssessmentReviewer")

  prescribedMedications    MedicationRequest[]        @relation("MedicationPrescriber")
  administeredMedications  MedicationAdministration[] @relation("MedicationAdministrator")

  // Phase 3: Workforce
  shiftAssignments   ShiftAssignment[]
  staffAvailability  StaffAvailability[]
  transfersPerformed Transfer[] @relation("TransferPerformer")

  // Phase 3: Patient Flow
  primaryEncounters Encounter[] @relation("EncounterPrimaryPractitioner")

  // Phase 3: Shift Swaps
  swapRequestsMade     ShiftSwapRequest[] @relation("SwapRequester")
  swapRequestsReceived ShiftSwapRequest[] @relation("SwapResponder")
  swapRequestsApproved ShiftSwapRequest[] @relation("SwapApprover")

  // Phase 3: Discharge Planning
  dischargePlansCreated   DischargePlan[] @relation("DischargePlanCreator")
  dischargePlansCompleted DischargePlan[] @relation("DischargePlanCompleter")
  dischargeTasksAssigned  DischargeTask[] @relation("DischargeTaskAssignee")
  dischargeTasksCompleted DischargeTask[] @relation("DischargeTaskCompleter")

  // Multi-tenancy memberships
  memberships UserTenantMembership[] @relation("UserMemberships")

  // Encryption: blind index for email lookup
  emailIndex String?

  @@index([tenantId])
  @@map("users")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  createdAt  DateTime @default(now())

  tenantId String?
  tenant   Organization? @relation("TenantAuditLogs", fields: [tenantId], references: [id])

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@index([tenantId])
  @@map("audit_logs")
}

// ─── EPR: Organization ────────────────────────────────

model Organization {
  id           String           @id @default(uuid())
  active       Boolean          @default(true)
  name         String
  type         OrganizationType
  odsCode      String?          @unique
  phone        String?
  email        String?
  addressLine1 String?
  city         String?
  postalCode   String?
  country      String?          @default("GB")

  // Stripe billing
  stripeCustomerId String? @unique

  parentId String?
  parent   Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  children Organization[] @relation("OrgHierarchy")

  // Managing organization relation (FHIR semantics)
  patients      Patient[]
  practitioners Practitioner[]

  // Tenant back-relations
  users               User[]           @relation("TenantUsers")
  tenantPatients      Patient[]        @relation("TenantPatients")
  tenantPractitioners Practitioner[]   @relation("TenantPractitioners")
  tenantPatientEvents PatientEvent[]   @relation("TenantPatientEvents")
  tenantAuditLogs     AuditLog[]       @relation("TenantAuditLogs")
  tenantCarePlans     CarePlan[]       @relation("TenantCarePlans")
  tenantAssessments     Assessment[]           @relation("TenantAssessments")
  tenantAssessmentTypes AssessmentTypeConfig[] @relation("TenantAssessmentTypes")
  tenantSpecialtyTypes  SpecialtyConfig[]      @relation("TenantSpecialtyTypes")

  tenantMedications       Medication[]               @relation("TenantMedications")
  tenantMedicationRequests MedicationRequest[]        @relation("TenantMedicationRequests")
  tenantMedicationAdmins  MedicationAdministration[] @relation("TenantMedicationAdmins")

  // Phase 3: Workforce
  tenantShiftPatterns    ShiftPattern[]      @relation("TenantShiftPatterns")
  tenantShifts           Shift[]             @relation("TenantShifts")
  tenantStaffAvailability StaffAvailability[] @relation("TenantStaffAvailability")

  // Phase 3: Patient Flow
  tenantLocations  Location[]  @relation("TenantLocations")
  tenantBeds       Bed[]       @relation("TenantBeds")
  tenantEncounters Encounter[] @relation("TenantEncounters")

  // Phase 3: Shift Swaps
  tenantSwapRequests ShiftSwapRequest[] @relation("TenantSwapRequests")

  // Phase 3: Discharge Planning
  tenantDischargePlans DischargePlan[] @relation("TenantDischargePlans")

  // Multi-tenancy memberships
  tenantMemberships UserTenantMembership[] @relation("TenantMemberships")

  subscription Subscription?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@map("organizations")
}

model Subscription {
  id                   String             @id @default(uuid())
  organizationId       String             @unique
  organization         Organization       @relation(fields: [organizationId], references: [id])
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  patientLimit         Int                @default(10)
  userLimit            Int                @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

// ─── EPR: Practitioner ────────────────────────────────

model Practitioner {
  id                 String  @id @default(uuid())
  active             Boolean @default(true)
  givenName          String
  familyName         String
  gender             Gender?
  phone              String?
  email              String?
  specialty          String?
  registrationNumber String?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  tenantId String
  tenant   Organization @relation("TenantPractitioners", fields: [tenantId], references: [id])

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  gpPatients         Patient[]          @relation("PatientGP")
  assignedActivities CarePlanActivity[] @relation("ActivityAssignee")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Encryption: blind indexes for name lookup
  givenNameIndex  String?
  familyNameIndex String?

  @@index([familyName, givenName])
  @@index([organizationId])
  @@index([tenantId])
  @@map("practitioners")
}

// ─── EPR: Patient ─────────────────────────────────────

model Patient {
  id           String        @id @default(uuid())
  active       Boolean       @default(true)
  status       PatientStatus @default(ACTIVE)
  givenName    String
  middleName   String?
  familyName   String
  prefix       String?
  gender       Gender
  birthDate    DateTime      @db.Date
  deceasedDate DateTime?
  addressLine1 String?
  addressLine2 String?
  city         String?
  district     String?
  postalCode   String?
  country      String?       @default("GB")
  phone        String?
  email        String?
  maritalStatus String?
  careSetting  String?

  managingOrganizationId String?
  managingOrganization   Organization? @relation(fields: [managingOrganizationId], references: [id])

  tenantId String
  tenant   Organization @relation("TenantPatients", fields: [tenantId], references: [id])

  gpPractitionerId String?
  gpPractitioner   Practitioner? @relation("PatientGP", fields: [gpPractitionerId], references: [id])

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  identifiers  PatientIdentifier[]
  contacts     PatientContact[]
  events       PatientEvent[]
  carePlans    CarePlan[]
  assessments  Assessment[]

  medicationRequests       MedicationRequest[]
  medicationAdministrations MedicationAdministration[]

  // Phase 3: Patient Flow
  encounters Encounter[]

  // Encryption: blind index for postal code lookup, search index for name search
  postalCodeIndex String?
  searchIndexes   PatientSearchIndex[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([familyName, givenName])
  @@index([birthDate])
  @@index([managingOrganizationId])
  @@index([tenantId])
  @@map("patients")
}

model PatientIdentifier {
  id        String         @id @default(uuid())
  patientId String
  type      IdentifierType
  system    String
  value     String
  isPrimary Boolean        @default(false)

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Encryption: blind index for identifier lookup (NHS number, MRN)
  valueIndex String?

  @@unique([type, value])
  @@index([patientId])
  @@index([value])
  @@map("patient_identifiers")
}

model PatientContact {
  id           String              @id @default(uuid())
  patientId    String
  relationship ContactRelationship
  givenName    String
  familyName   String
  phone        String?
  email        String?
  addressLine1 String?
  city         String?
  postalCode   String?

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@map("patient_contacts")
}

model PatientEvent {
  id           String           @id @default(uuid())
  patientId    String
  eventType    PatientEventType
  summary      String
  detail       Json?
  careSetting  String?
  occurredAt   DateTime         @default(now())
  recordedAt   DateTime         @default(now())
  recordedById String

  tenantId String
  tenant   Organization @relation("TenantPatientEvents", fields: [tenantId], references: [id])

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  recordedBy User    @relation("PatientEventRecorder", fields: [recordedById], references: [id])

  @@index([patientId, occurredAt])
  @@index([patientId, eventType])
  @@index([careSetting])
  @@index([tenantId])
  @@map("patient_events")
}

// ─── EPR: Care Plans ─────────────────────────────────

model CarePlan {
  id             String           @id @default(uuid())
  title          String
  description    String?
  status         CarePlanStatus   @default(DRAFT)
  category       CarePlanCategory @default(GENERAL)
  startDate      DateTime         @db.Date
  endDate        DateTime?        @db.Date
  nextReviewDate DateTime?        @db.Date

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  authorId String
  author   User @relation("CarePlanAuthor", fields: [authorId], references: [id])

  tenantId String
  tenant   Organization @relation("TenantCarePlans", fields: [tenantId], references: [id])

  goals      CarePlanGoal[]
  activities CarePlanActivity[]
  notes      CarePlanNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, status])
  @@index([tenantId])
  @@index([authorId])
  @@index([nextReviewDate])
  @@map("care_plans")
}

model CarePlanGoal {
  id          String     @id @default(uuid())
  carePlanId  String
  carePlan    CarePlan   @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  description String
  status      GoalStatus @default(PROPOSED)
  targetDate  DateTime?  @db.Date
  measure     String?
  notes       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carePlanId])
  @@map("care_plan_goals")
}

model CarePlanActivity {
  id          String         @id @default(uuid())
  carePlanId  String
  carePlan    CarePlan       @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  type        ActivityType   @default(OTHER)
  status      ActivityStatus @default(NOT_STARTED)
  description String
  scheduledAt DateTime?
  notes       String?

  assigneeId String?
  assignee   Practitioner? @relation("ActivityAssignee", fields: [assigneeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([carePlanId])
  @@index([assigneeId])
  @@index([scheduledAt])
  @@map("care_plan_activities")
}

model CarePlanNote {
  id         String   @id @default(uuid())
  carePlanId String
  carePlan   CarePlan @relation(fields: [carePlanId], references: [id], onDelete: Cascade)
  content    String
  authorId   String
  author     User     @relation("CarePlanNoteAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())

  @@index([carePlanId, createdAt])
  @@map("care_plan_notes")
}

// ─── EPR: Assessment Type Config ─────────────────────

model AssessmentTypeConfig {
  id          String  @id @default(uuid())
  code        String
  name        String
  description String?
  category    String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  tenantId String?
  tenant   Organization? @relation("TenantAssessmentTypes", fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([isActive])
  @@map("assessment_type_configs")
}

// ─── EPR: Specialty Config ──────────────────────────

model SpecialtyConfig {
  id          String  @id @default(uuid())
  code        String
  name        String
  description String?
  category    String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  tenantId String?
  tenant   Organization? @relation("TenantSpecialtyTypes", fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([isActive])
  @@map("specialty_configs")
}

// ─── EPR: Assessments ───────────────────────────────

model Assessment {
  id                  String           @id @default(uuid())
  title               String
  description         String?
  assessmentType      String
  toolName            String?
  status              AssessmentStatus @default(COMPLETED)
  score               Int?
  maxScore            Int?
  scoreInterpretation String?
  riskLevel           RiskLevel?
  performedAt         DateTime         @default(now())
  notes               String?
  recommendedActions  String?
  responses           Json?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  performedById String
  performedBy   User @relation("AssessmentPerformer", fields: [performedById], references: [id])

  reviewedById String?
  reviewedBy   User?    @relation("AssessmentReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  tenantId String
  tenant   Organization @relation("TenantAssessments", fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, performedAt])
  @@index([patientId, assessmentType])
  @@index([assessmentType, riskLevel])
  @@index([tenantId])
  @@map("assessments")
}

// ─── EPR: Medications (EPMA) ─────────────────────────

model Medication {
  id           String         @id @default(uuid())
  name         String
  genericName  String?
  code         String?
  form         MedicationForm @default(TABLET)
  strength     String?
  manufacturer String?
  isActive     Boolean        @default(true)

  tenantId String?
  tenant   Organization? @relation("TenantMedications", fields: [tenantId], references: [id])

  requests        MedicationRequest[]
  administrations MedicationAdministration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([code])
  @@index([tenantId])
  @@map("medications")
}

model MedicationRequest {
  id             String                  @id @default(uuid())
  status         MedicationRequestStatus @default(DRAFT)
  priority       String?
  dosageText     String
  dose           String?
  frequency      String?
  route          MedicationRoute         @default(ORAL)
  startDate      DateTime                @db.Date
  endDate        DateTime?               @db.Date
  reasonText     String?
  instructions   String?
  asNeeded       Boolean                 @default(false)
  asNeededReason String?
  maxDosePerDay  String?

  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  prescriberId String
  prescriber   User @relation("MedicationPrescriber", fields: [prescriberId], references: [id])

  tenantId String
  tenant   Organization @relation("TenantMedicationRequests", fields: [tenantId], references: [id])

  administrations MedicationAdministration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, status])
  @@index([medicationId])
  @@index([tenantId])
  @@index([prescriberId])
  @@map("medication_requests")
}

model MedicationAdministration {
  id             String               @id @default(uuid())
  status         MedicationAdminStatus @default(COMPLETED)
  occurredAt     DateTime             @default(now())
  doseGiven      String?
  route          MedicationRoute?
  site           String?
  notes          String?
  notGivenReason String?

  requestId String
  request   MedicationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id])

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  performerId String
  performer   User @relation("MedicationAdministrator", fields: [performerId], references: [id])

  tenantId String
  tenant   Organization @relation("TenantMedicationAdmins", fields: [tenantId], references: [id])

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([patientId, occurredAt])
  @@index([tenantId])
  @@map("medication_administrations")
}

// ─── Phase 3: Workforce ─────────────────────────────────

model ShiftPattern {
  id           String    @id @default(uuid())
  name         String
  shiftType    ShiftType
  startTime    String    // HH:mm format
  endTime      String    // HH:mm format
  breakMinutes Int       @default(0)
  color        String?   // hex color for UI
  isActive     Boolean   @default(true)

  tenantId String
  tenant   Organization @relation("TenantShiftPatterns", fields: [tenantId], references: [id])

  shifts Shift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("shift_patterns")
}

model Shift {
  id     String      @id @default(uuid())
  date   DateTime    @db.Date
  status ShiftStatus @default(DRAFT)
  notes  String?

  shiftPatternId String
  shiftPattern   ShiftPattern @relation(fields: [shiftPatternId], references: [id])

  locationId String?
  location   Location? @relation("ShiftLocation", fields: [locationId], references: [id])

  tenantId String
  tenant   Organization @relation("TenantShifts", fields: [tenantId], references: [id])

  assignments ShiftAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, date])
  @@index([shiftPatternId])
  @@index([locationId])
  @@index([date, status])
  @@map("shifts")
}

model ShiftAssignment {
  id          String    @id @default(uuid())
  role        String?   // role during this shift
  confirmedAt DateTime?

  shiftId String
  shift   Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  // Phase 3: Shift Swaps
  swapRequestsAsOriginal ShiftSwapRequest[] @relation("SwapOriginal")
  swapRequestsAsTarget   ShiftSwapRequest[] @relation("SwapTarget")

  @@unique([shiftId, userId])
  @@index([userId])
  @@index([shiftId])
  @@map("shift_assignments")
}

model StaffAvailability {
  id        String           @id @default(uuid())
  date      DateTime         @db.Date               // start date
  endDate   DateTime?        @db.Date               // end date (null = single day)
  type      AvailabilityType
  startTime String?          // HH:mm, null = all day
  endTime   String?          // HH:mm, null = all day
  notes     String?

  userId String
  user   User @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Organization @relation("TenantStaffAvailability", fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([tenantId, date])
  @@map("staff_availability")
}

// ─── Phase 3: Patient Flow ──────────────────────────────

model Location {
  id       String       @id @default(uuid())
  name     String
  type     LocationType
  ward     String?
  floor    String?
  status   String       @default("ACTIVE")
  capacity Int          @default(0)

  parentId String?
  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[] @relation("LocationHierarchy")

  tenantId String
  tenant   Organization @relation("TenantLocations", fields: [tenantId], references: [id])

  beds              Bed[]
  shifts            Shift[]      @relation("ShiftLocation")
  encounters        Encounter[]  @relation("EncounterLocation")
  transfersFrom     Transfer[]   @relation("TransferFromLocation")
  transfersTo       Transfer[]   @relation("TransferToLocation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([parentId])
  @@index([type])
  @@map("locations")
}

model Bed {
  id         String    @id @default(uuid())
  identifier String
  status     BedStatus @default(AVAILABLE)
  notes      String?

  locationId String
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Organization @relation("TenantBeds", fields: [tenantId], references: [id])

  encounters    Encounter[]  @relation("EncounterBed")
  transfersFrom Transfer[]   @relation("TransferFromBed")
  transfersTo   Transfer[]   @relation("TransferToBed")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([locationId, identifier])
  @@index([tenantId])
  @@index([status])
  @@map("beds")
}

model Encounter {
  id                   String                @id @default(uuid())
  status               EncounterStatus       @default(PLANNED)
  class                EncounterClass        @default(INPATIENT)
  admissionSource      AdmissionSource?
  admissionDate        DateTime              @default(now())
  dischargeDate        DateTime?
  dischargeDestination DischargeDestination?
  notes                String?

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id])

  locationId String?
  location   Location? @relation("EncounterLocation", fields: [locationId], references: [id])

  bedId String?
  bed   Bed?    @relation("EncounterBed", fields: [bedId], references: [id])

  primaryPractitionerId String?
  primaryPractitioner   User? @relation("EncounterPrimaryPractitioner", fields: [primaryPractitionerId], references: [id])

  tenantId String
  tenant   Organization @relation("TenantEncounters", fields: [tenantId], references: [id])

  transfers     Transfer[]
  dischargePlan DischargePlan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([patientId])
  @@index([locationId])
  @@index([bedId])
  @@map("encounters")
}

model Transfer {
  id            String   @id @default(uuid())
  transferredAt DateTime @default(now())
  reason        String?

  encounterId String
  encounter   Encounter @relation(fields: [encounterId], references: [id], onDelete: Cascade)

  fromLocationId String?
  fromLocation   Location? @relation("TransferFromLocation", fields: [fromLocationId], references: [id])

  toLocationId String
  toLocation   Location @relation("TransferToLocation", fields: [toLocationId], references: [id])

  fromBedId String?
  fromBed   Bed?   @relation("TransferFromBed", fields: [fromBedId], references: [id])

  toBedId String?
  toBed   Bed?   @relation("TransferToBed", fields: [toBedId], references: [id])

  transferredById String
  transferredBy   User @relation("TransferPerformer", fields: [transferredById], references: [id])

  createdAt DateTime @default(now())

  @@index([encounterId])
  @@index([transferredAt])
  @@map("transfers")
}

// ─── Phase 3: Shift Swap Marketplace ────────────────────

model ShiftSwapRequest {
  id          String          @id @default(uuid())
  status      ShiftSwapStatus @default(PENDING)
  reason      String?
  managerNote String?

  requesterId               String
  requester                 User            @relation("SwapRequester", fields: [requesterId], references: [id])

  originalShiftAssignmentId String
  originalShiftAssignment   ShiftAssignment @relation("SwapOriginal", fields: [originalShiftAssignmentId], references: [id])

  targetShiftAssignmentId   String?
  targetShiftAssignment     ShiftAssignment? @relation("SwapTarget", fields: [targetShiftAssignmentId], references: [id])

  responderId               String?
  responder                 User?           @relation("SwapResponder", fields: [responderId], references: [id])

  approvedById              String?
  approvedBy                User?           @relation("SwapApprover", fields: [approvedById], references: [id])

  tenantId String
  tenant   Organization @relation("TenantSwapRequests", fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([requesterId])
  @@index([responderId])
  @@index([originalShiftAssignmentId])
  @@map("shift_swap_requests")
}

// ─── Phase 3: Discharge Planning ────────────────────────

model DischargePlan {
  id          String              @id @default(uuid())
  status      DischargePlanStatus @default(DRAFT)
  plannedDate DateTime?           @db.Date
  actualDate  DateTime?
  notes       String?

  encounterId String    @unique
  encounter   Encounter @relation(fields: [encounterId], references: [id])

  createdById String
  createdBy   User   @relation("DischargePlanCreator", fields: [createdById], references: [id])

  completedById String?
  completedBy   User?  @relation("DischargePlanCompleter", fields: [completedById], references: [id])

  tenantId String
  tenant   Organization @relation("TenantDischargePlans", fields: [tenantId], references: [id])

  tasks DischargeTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([encounterId])
  @@map("discharge_plans")
}

model DischargeTask {
  id          String              @id @default(uuid())
  type        DischargeTaskType
  status      DischargeTaskStatus @default(PENDING)
  notes       String?
  completedAt DateTime?

  dischargePlanId String
  dischargePlan   DischargePlan @relation(fields: [dischargePlanId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?  @relation("DischargeTaskAssignee", fields: [assignedToId], references: [id])

  completedById String?
  completedBy   User?  @relation("DischargeTaskCompleter", fields: [completedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dischargePlanId])
  @@index([assignedToId])
  @@map("discharge_tasks")
}

// ─── Encryption: Patient Search Index ───────────────────

model PatientSearchIndex {
  id        String @id @default(uuid())
  patientId String
  tenantId  String
  fieldName String
  tokenHash String

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([tenantId, tokenHash])
  @@index([patientId])
  @@map("patient_search_index")
}

// ─── Encryption Key Management ─────────────────────────

model EncryptionKey {
  id           String    @id @default(uuid())
  tenantId     String
  encryptedDek String
  keyVersion   Int       @default(1)
  isActive     Boolean   @default(true)
  algorithm    String    @default("AES-256-GCM")
  kmsKeyArn    String?
  createdAt    DateTime  @default(now())
  rotatedAt    DateTime?

  @@unique([tenantId, keyVersion])
  @@index([tenantId, isActive])
  @@map("encryption_keys")
}
