{
  "uid": "clinvara-errors",
  "title": "Clinvara — Errors",
  "tags": ["clinvara", "errors"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Exceptions per second by status code",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_exceptions_total[1m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Exceptions per second by class",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_exceptions_total[1m])) by (exception_class)",
          "legendFormat": "{{exception_class}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Top exception classes (last 1h)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "topk(10, sum(increase(http_exceptions_total[1h])) by (exception_class, status_code))",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
