{
  "uid": "clinvara-database",
  "title": "Clinvara — Database",
  "tags": ["clinvara", "database"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Prisma query rate by action",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (action) (rate(prisma_query_duration_seconds_count[1m]))",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Prisma query p95 latency by action",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(prisma_query_duration_seconds_bucket[5m])) by (le, action))",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Top 10 slowest models (p95, last 5m)",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "topk(10, histogram_quantile(0.95, sum(rate(prisma_query_duration_seconds_bucket[5m])) by (le, model, action)))",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Prisma errors by class (last 1h)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "targets": [
        {
          "expr": "sum by (error_class) (rate(prisma_query_errors_total[5m]))",
          "legendFormat": "{{error_class}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Postgres connections in use",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "targets": [{ "expr": "pg_stat_activity_count", "legendFormat": "active" }]
    },
    {
      "id": 6,
      "title": "Postgres connection saturation",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus-prod" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count) / pg_settings_max_connections",
          "instant": true
        }
      ]
    }
  ]
}
